# Global settings
font=JetBrainsMono Nerd Font 12
width=300
margin=10
padding=10
border-size=2
border-radius=5
default-timeout=5000
ignore-timeout=0
max-visible=3
layer=overlay
anchor=top-right

background-color=#000000

[urgency=low]
default-timeout=5000
border-color=#808080

[urgency=normal]
default-timeout=10000

[urgency=high]
default-timeout=50000
border-color=#ff0000
